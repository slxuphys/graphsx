{
  "name": "graphsx-vscode",
  "displayName": "GraphSX",
  "description": "Render GraphSX fenced code blocks in VS Code Markdown previews and notebook Markdown cells.",
  "version": "0.1.0",
  "publisher": "slxuphys",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/slxuphys/graphsx.git",
    "directory": "packages/vscode-graphsx"
  },
  "homepage": "https://slxuphys.github.io/graphsx/",
  "bugs": {
    "url": "https://github.com/slxuphys/graphsx/issues"
  },
  "keywords": [
    "graphsx",
    "markdown",
    "notebook",
    "diagram",
    "plot",
    "svg"
  ],
  "galleryBanner": {
    "color": "#eef6ff",
    "theme": "light"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onLanguage:markdown",
    "onNotebook:jupyter-notebook"
  ],
  "contributes": {
    "languages": [
      {
        "id": "graphsx",
        "aliases": [
          "GraphSX",
          "graphsx"
        ]
      }
    ],
    "grammars": [
      {
        "language": "graphsx",
        "scopeName": "source.graphsx",
        "path": "./syntaxes/graphsx.tmLanguage.json"
      },
      {
        "scopeName": "markdown.graphsx.codeblock",
        "path": "./syntaxes/graphsx-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.graphsx": "graphsx"
        }
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/preview.js"
    ],
    "markdown.previewStyles": [
      "./dist/preview.css"
    ],
    "notebookRenderer": [
      {
        "id": "slxuphys.graphsx.markdown-it-renderer",
        "displayName": "GraphSX Markdown Renderer",
        "entrypoint": {
          "extends": "vscode.markdown-it-renderer",
          "path": "./dist/notebook-renderer.js"
        }
      }
    ]
  },
  "scripts": {
    "build": "node ../../scripts/build-vscode-extension.js"
  },
  "files": [
    "assets",
    "dist",
    "syntaxes",
    "README.md",
    "package.json"
  ]
}
