{
  "name": "vscode-graphsx",
  "displayName": "GraphSX",
  "description": "Render GraphSX fenced code blocks in VS Code's built-in Markdown preview.",
  "version": "0.1.0",
  "publisher": "slxu",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onLanguage:markdown",
    "onNotebook:jupyter-notebook"
  ],
  "contributes": {
    "languages": [
      {
        "id": "graphsx",
        "aliases": [
          "GraphSX",
          "graphsx"
        ]
      }
    ],
    "grammars": [
      {
        "language": "graphsx",
        "scopeName": "source.graphsx",
        "path": "./syntaxes/graphsx.tmLanguage.json"
      },
      {
        "scopeName": "markdown.graphsx.codeblock",
        "path": "./syntaxes/graphsx-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.graphsx": "graphsx"
        }
      }
    ],
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/preview.js"
    ],
    "markdown.previewStyles": [
      "./dist/preview.css"
    ]
  },
  "scripts": {
    "build": "node ../../scripts/build-vscode-extension.js"
  },
  "files": [
    "dist",
    "syntaxes",
    "README.md",
    "package.json"
  ]
}
