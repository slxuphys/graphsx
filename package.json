{
  "name": "@slxu/graphsx",
  "version": "0.1.1",
  "description": "A small React-like inline graph DSL parser and model builder.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./codemirror": "./src/codemirror.js",
    "./codemirror.css": "./src/codemirror.css",
    "./markdown.css": "./src/markdown.css"
  },
  "files": [
    "src/index.js",
    "src/errors.js",
    "src/literals.js",
    "src/markup.js",
    "src/parser.js",
    "src/plot.js",
    "src/plot-math.js",
    "src/plot-renderer.js",
    "src/renderer.js",
    "src/markdown.js",
    "src/markdown.css",
    "src/codemirror.js",
    "src/codemirror.css",
    "src/document.js",
    "docs/assets/*.svg",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "build:pages": "vite build --base=/graphsx/",
    "build:vscode": "node scripts/build-vscode-extension.js",
    "dev": "vite --host 127.0.0.1",
    "generate:readme-assets": "node scripts/generate-readme-assets.js",
    "playground": "vite --host 127.0.0.1",
    "test": "node --test"
  },
  "keywords": [
    "graph",
    "dsl",
    "parser",
    "diagram"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1"
  },
  "peerDependenciesMeta": {
    "@codemirror/state": {
      "optional": true
    },
    "@codemirror/view": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "codemirror": "^6.0.2",
    "esbuild": "^0.27.7",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "vite": "^7.0.0"
  }
}
